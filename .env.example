# 本地模型
LLM_MODEL_PATH=./models/Qwen2.5-VL-7B-Instruct
EMBEDDING_MODEL_PATH=./models/bge-m3

# Web Search
SERPER_API_KEY=

# 本地知识库 / 向量索引
SEMANTIC_QDRANT_PATH=./data/memory/qdrant
QDRANT_LOCK_TIMEOUT_SECONDS=180

# 短期记忆
SHORT_TERM_MAX_MESSAGES=12
SHORT_TERM_MAX_APPROX_TOKENS=2400
SHORT_TERM_SUMMARY_THRESHOLD=8

# 长期记忆
LONG_TERM_TOP_K=3
ENABLE_PROFILE_MEMORY=true
ENABLE_SEMANTIC_MEMORY=true
SEMANTIC_MEMORY_COLLECTION=agent_semantic_memory
PROFILE_STORAGE_PATH=./data/memory/profiles.sqlite3

# Redis 短期记忆
MEMORY_REDIS_HOST=127.0.0.1
MEMORY_REDIS_PORT=6379
MEMORY_REDIS_DB=0
MEMORY_REDIS_PASSWORD=
MEMORY_REDIS_TIMEOUT=2.0
MEMORY_REDIS_PREFIX=agent:short_term
